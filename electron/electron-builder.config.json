{
  "appId": "com.yourdoamnin.yourapp",
  "directories": {
    "output": "../releases",
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "linux": {
    "icon": "assets/appIcon.png",
    "target": [
      "AppImage",
      "deb"
    ]
  },
  "win": {
    "target": [{
      "target": "portable",
      "arch": ["x64"]
    }],
    "icon": "assets/appIcon.png"
  },
  "mac": {
    "category": "your.app.category.type",
    "target": "dmg"
  }
}