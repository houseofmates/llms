{
  "name": "llms",
  "version": "1.0.0",
  "description": "cross-platform web application",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'script.js' 'server.js'",
    "format:check": "prettier --check 'script.js' 'server.js'",
    "build:css": "npx tailwindcss -i ./styles.tailwind.css -o ./styles.css --minify",
    "build": "npm run build:css && mkdir -p dist && cp index.html dist/ && cp script.js dist/ && cp styles.css dist/ && cp telemetry.js dist/ && cp llama-offline.js dist/ && cp tools-system.js dist/ && npx cap sync && cp -rf dist/* electron/app/",
    "start": "node server.js",
    "android:build": "cd android && ./gradlew assembleDebug",
    "rebuild-all": "bash rebuild-all.sh",
    "watch": "chokidar 'index.html' 'script.js' 'styles.css' 'android/app/src/main/assets/public/**' -c 'npm run rebuild-all' --debounce 2000"
  },
  "keywords": [],
  "author": "house",
  "license": "ISC",
  "dependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "chokidar-cli": "^3.0.0",
    "electron": "^40.8.5",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.5.15",
    "autoprefixer": "^10.4.0"
  }
}
