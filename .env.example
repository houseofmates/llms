# copy to .env on your personal build machine.
# the .env file is gitignored - it never leaves your machine.
#
# run `npm run build` (or `npm run bundle:env` standalone) to bake these keys
# into dist/rp-keys.bundled.js. that file is picked up by the rp module on
# every page load and takes precedence over any keys saved in the ui.
#
# the same dist/ tree is what `npx cap sync` copies into the android apk and
# what gets copied into electron/app/ - so web, apk, and electron all share
# the same bundled keys.

# nvidia nim keys for the rp module (kimi-k2.6 + nvidia embeddings).
# add as many as you want; numbered keys are joined with commas into the
# rotation pool. start at 1.
NVIDIA_API_KEY_1=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NVIDIA_API_KEY_2=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NVIDIA_API_KEY_3=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
